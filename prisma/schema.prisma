generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Service {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  type        String   // 'interno', 'externo', 'mixto'
  status      Boolean  @default(true) // true for active, false for inactive
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Provider {
  id           Int      @id @default(autoincrement())
  businessName String
  contactName  String?
  phone        String?
  email        String?
  address      String?
  notes        String?
  status       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
